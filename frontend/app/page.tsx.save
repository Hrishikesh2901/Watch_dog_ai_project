                              <div className="w-20 h-20 rounded-2xl bg-white dark:bg-slate-900 border-2 border-blue-100 dark:border-blue-900 flex items-center justify-center mb-6 shadow-lg shadow-blue-500/10 group-hover:scale-110 group-hover:shadow-blue-500/30 group-hover:border-blue-500 transition-all duration-300">
                                  <item.icon className="w-8 h-8 text-blue-600 dark:text-blue-400" />
                              </div>
                              <h3 className="text-2xl font-bold mb-3 text-slate-900 dark:text-white group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">{item.title}</h3>
