                  Citizen-Led AI Audit Platform
                </div>
            </motion.div>
            <h1 className="text-6xl md:text-8xl font-bold text-slate-900 dark:text-white tracking-tight mb-6">
               The People&apos;s <br /> 
               <span className="bg-clip-text text-transparent bg-gradient-to-r from-blue-600 via-purple-600 to-pink-600">AI Watchdog</span>
            </h1>
            <p className="text-xl text-slate-600 dark:text-slate-300 max-w-2xl mx-auto mb-10 leading-relaxed">
