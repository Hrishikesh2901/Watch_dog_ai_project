      {/* Objectives Section */}
      <section id="objectives" className="py-20 px-4 bg-white dark:bg-slate-950 relative">
        <div className="container mx-auto">
            <motion.h2 
                initial={{ opacity: 0 }}
                whileInView={{ opacity: 1 }}
                className="text-4xl font-bold text-center mb-16 text-slate-900 dark:text-white"
            >
                Our Core Objectives
            </motion.h2>
            
            <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
                <ObjectiveCard 
                    title="Centralize Experiences"
                    why="Citizens face unexplained rejections in housing, visas, jobs."
                    example="MHADA housing lottery applicant marked 'Not Selected' with no reason."
                    gradient="bg-blue-500"
                />
                <ObjectiveCard 
                    title="Anonymize Data"
                    why="Citizens share sensitive IDs like Aadhaar for validation."
                    example="Aadhaar-linked ration denial reports redacted for privacy."
                    gradient="bg-purple-500"
                />
                 <ObjectiveCard 
                    title="Extract Metadata"
                    why="Raw text needs structure for pattern recognition."
                    example="Visa rejection -> {Type: Visa, Reason: Section 214(b)}."
                    gradient="bg-pink-500"
                />
                <ObjectiveCard 
                    title="Visualize Bias"
                    why="Transparency emerges only when cases are seen collectively."
                    example="Heatmap shows high biometric mismatch denials in Bihar."
                    gradient="bg-orange-500"
                />
