        </div>
      </section>

      {/* Features Section */}
      <section id="features" className="bg-slate-50 dark:bg-slate-900/50 relative">
        <div className="absolute inset-0 z-0 opacity-40 overflow-hidden">
                <Hyperspeed effectOptions={{
                    onSpeedUp: () => { },
                    onSlowDown: () => { },
                    distortion: 'turbulentDistortion',
                    length: 400,
